# ─────────────────────────────────────────────
#  SUPABASE  (get from: https://app.supabase.com → Project Settings → API)
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ─────────────────────────────────────────────
#  RESEND  (get from: https://resend.com → API Keys)
# ─────────────────────────────────────────────
RESEND_API_KEY=re_YOUR_API_KEY
RESEND_FROM_EMAIL=alerts@yourbank.com

# ─────────────────────────────────────────────
#  APP
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BANK_NAME=Your Bank Name

# ─────────────────────────────────────────────
#  CRON SECRET  (set any random string — used to protect the cron endpoint)
# ─────────────────────────────────────────────
CRON_SECRET=your_random_secret_here
